# TRES Finance plugin — environment variable reference
#
# This file documents the environment variables used by this plugin.
# Copy to .env and fill in your values (never commit .env).
#
# In normal use, these values are stored in the OS keychain via the
# Claude Code plugin userConfig mechanism and do NOT need to be set
# as shell environment variables. This file exists for documentation
# and for advanced / CI use cases only.

# Your DeBank Pro API key (obtain at https://cloud.debank.com)
# Required only for the tres-asset-balance-validation skill.
DEBANK_API_KEY=<your-debank-api-key>
